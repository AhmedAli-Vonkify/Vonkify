---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ContactSection from '../../components/ContactSection.astro';
import { useTranslations } from '../../i18n';

const t = useTranslations('nl');

const faqs = [
  { q: 'Wat is uw huidige beschikbaarheid?', a: 'Ik ben beschikbaar voor freelanceprojecten vanaf Q2 2026. Ik kan full-time opdrachten, parttime (3-4 dagen/week) of projectgebaseerd werk aannemen.' },
  { q: 'Wat is uw uurtarief?', a: 'Mijn tarief hangt af van de projectomvang, looptijd en complexiteit. Als senior .NET & AI specialist zijn mijn tarieven concurrerend met de Nederlandse markt. Laten we er samen over praten.' },
  { q: 'Werkt u op afstand?', a: 'Ja, ik werk volledig vanuit huis. Ik sta ook open voor hybride afspraken in Nederland (vooral in de omgeving Rotterdam/Utrecht).' },
  { q: 'Welke projecten neemt u aan?', a: 'Enterprise .NET/AI applicaties, API/middleware platformen, full-stack webapps (Angular + React + .NET), cloudarchitectuur op Azure en AI-integratieprojecten (RAG, LLMs, agents).' },
  { q: 'Werkt u alleen of in een team?', a: 'Beide. Ik kan zelfstandig werken als solo opdrachtnemer of ingebed worden in uw bestaande ontwikkelteam. Ik ben ervaren in het snel onboarden in bestaande codebases.' },
  { q: 'Wat is uw minimale projectgrootte?', a: 'Ik geef de voorkeur aan projecten van minimaal 1 maand looptijd voor kwalitatieve oplevering. Voor kleinere taken sta ik open voor consultancyopdrachten.' },
];
---

<BaseLayout title={t('contact.page.title')} description={t('contact.page.desc')}>
  <Header />
  <main class="pt-20">
    <section class="section-dark py-16 px-4 text-center">
      <div class="max-w-2xl mx-auto">
        <div class="inline-flex items-center gap-2 mb-5 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
          {t('contact.chip')}
        </div>
        <h1 class="section-heading text-text-light mb-4">{t('contact.page.heading')}</h1>
        <p class="text-cool-gray text-lg">{t('contact.page.sub')}</p>
      </div>
    </section>

    <ContactSection />

    <section class="section-light dark:section-dark py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 reveal">
          <h2 class="text-2xl font-bold text-near-black dark:text-text-light mb-3">{t('contact.faq.heading')}</h2>
          <p class="text-cool-gray">{t('contact.faq.sub')}</p>
        </div>
        <div class="space-y-4">
          {faqs.map((faq) => (
            <details class="reveal group bg-white dark:bg-navy-light/40 border border-gray-100 dark:border-white/8 rounded-xl overflow-hidden hover:border-primary/25 transition-colors">
              <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none font-semibold text-near-black dark:text-text-light text-sm hover:text-primary transition-colors">
                {faq.q}
                <svg class="w-4 h-4 text-cool-gray flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-6 pb-5 text-sm text-cool-gray leading-relaxed border-t border-gray-50 dark:border-white/5 pt-4">{faq.a}</div>
            </details>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
