---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import ProjectCard from '../../../components/ProjectCard.astro';
import { useTranslations } from '../../../i18n';

const t = useTranslations('nl');
const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => a.data.order - b.data.order);

const categories = ['Alles', 'AI & ML', 'Backend', 'Full-Stack', 'Cloud', 'Blockchain', 'Healthcare'];
---

<BaseLayout
  title="Projecten — Vonkify | Senior .NET & AI Engineer Portfolio"
  description="Ontdek het portfolio van Ahmed Ali — enterprise softwareprojecten van AI-platformen tot blockchain-energiesystemen en medische EPD-oplossingen."
>
  <Header />
  <main class="pt-20">
    <section class="section-dark py-20 px-4">
      <div class="max-w-7xl mx-auto text-center">
        <div class="inline-flex items-center gap-2 mb-5 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
          {t('projects.portfolio')}
        </div>
        <h1 class="section-heading text-text-light mb-4">{t('projects.allHeading')}</h1>
        <p class="text-cool-gray max-w-2xl mx-auto text-lg">
          {allProjects.length} {t('projects.allSubheading')}
        </p>
      </div>
    </section>

    <section class="section-dark pb-24 px-4">
      <div class="max-w-7xl mx-auto">
        <div class="flex flex-wrap gap-2 justify-center mb-12" id="filter-buttons">
          {categories.map((cat) => (
            <button class={`filter-btn ${cat === 'Alles' ? 'active' : ''}`} data-category={cat === 'Alles' ? 'All' : cat}>
              {cat}
            </button>
          ))}
        </div>

        <div id="projects-grid" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sorted.map((project) => (
            <div class="project-item" data-category={project.data.category}>
              <ProjectCard
                slug={project.id}
                title={project.data.title}
                company={project.data.company}
                period={project.data.period}
                summary={project.data.summaryNl ?? project.data.summary}
                tech={project.data.tech}
                category={project.data.category}
                featured={project.data.featured}
              />
            </div>
          ))}
        </div>

        <div id="empty-state" class="hidden text-center py-20 text-cool-gray">
          <div class="text-5xl mb-4">🔍</div>
          <p>Geen projecten gevonden voor deze categorie.</p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('[data-category]');
  const projectItems = document.querySelectorAll<HTMLElement>('.project-item');
  const emptyState = document.getElementById('empty-state');

  filterButtons.forEach((btn) => {
    btn.addEventListener('click', () => {
      const category = btn.dataset.category;
      filterButtons.forEach((b) => b.classList.remove('active'));
      btn.classList.add('active');
      let visible = 0;
      projectItems.forEach((item) => {
        const matches = category === 'All' || item.dataset.category === category;
        item.style.display = matches ? 'block' : 'none';
        if (matches) visible++;
      });
      emptyState?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
