---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE, EXPERIENCE, TECH_CATEGORIES } from '../../utils/constants';
import { useTranslations } from '../../i18n';

const t = useTranslations('nl');
---

<BaseLayout title={t('cv.page.title')} description="Download of bekijk het professionele CV van Ahmed Ali — Senior Software Engineer met 10+ jaar enterprise-ervaring in Nederland.">
  <Header />
  <main class="pt-20">
    <section class="section-dark py-16 px-4">
      <div class="max-w-4xl mx-auto text-center">
        <h1 class="section-heading text-text-light mb-4">{t('cv.heading')}</h1>
        <p class="text-cool-gray mb-8">Ahmed Ali — Senior Software Engineer</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/ahmed-ali-cv.pdf" download class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
            </svg>
            {t('cv.download')}
          </a>
          <button onclick="window.print()" class="btn-secondary no-print">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
            </svg>
            {t('cv.print')}
          </button>
        </div>
      </div>
    </section>

    <section class="section-light dark:section-dark py-16 px-4">
      <div class="max-w-4xl mx-auto">
        <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-6 mb-10 pb-8 border-b border-gray-200 dark:border-white/10">
          <div>
            <h2 class="text-3xl font-bold text-near-black dark:text-text-light mb-1">Ahmed Ali</h2>
            <p class="text-lg text-primary font-semibold mb-3">Senior Software Engineer · AI Integratiespecialist</p>
            <div class="flex flex-wrap gap-x-4 gap-y-1.5 text-sm text-cool-gray">
              <a href={`mailto:${SITE.email}`} class="hover:text-primary transition-colors">{SITE.email}</a>
              <span>{SITE.phone}</span>
              <span>Rotterdam, Nederland</span>
              <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="hover:text-primary transition-colors">LinkedIn</a>
            </div>
          </div>
          <div class="flex items-center gap-2 text-xs font-semibold text-success bg-success/10 border border-success/20 px-4 py-2 rounded-full flex-shrink-0 self-start">
            <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse" />
            {t('cv.available')}
          </div>
        </div>

        <div class="mb-10">
          <h3 class="text-sm font-bold text-primary uppercase tracking-widest mb-4 flex items-center gap-2">
            <span class="w-8 h-px bg-primary" /> {t('cv.summary.heading')}
          </h3>
          <p class="text-cool-gray leading-relaxed">{t('cv.summary.text')}</p>
        </div>

        <div class="mb-10">
          <h3 class="text-sm font-bold text-primary uppercase tracking-widest mb-6 flex items-center gap-2">
            <span class="w-8 h-px bg-primary" /> {t('cv.experience')}
          </h3>
          <div class="space-y-8">
            {EXPERIENCE.map((job) => (
              <div class="relative pl-5 border-l-2 border-gray-200 dark:border-white/10 hover:border-primary transition-colors">
                <div class="absolute -left-[5px] top-1.5 w-2 h-2 bg-primary rounded-full" />
                <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2 mb-2">
                  <div>
                    <h4 class="font-bold text-near-black dark:text-text-light">{job.titleNl}</h4>
                    <p class="text-sm font-semibold text-primary">{job.company} <span class="text-cool-gray font-normal">· {job.locationNl}</span></p>
                  </div>
                  <span class="text-xs font-mono text-cool-gray bg-gray-100 dark:bg-white/5 px-2.5 py-1 rounded flex-shrink-0">{job.period}</span>
                </div>
                <p class="text-sm text-cool-gray leading-relaxed mb-2">{job.descriptionNl}</p>
                <p class="text-xs font-mono text-primary/70">{job.highlight}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="mb-10">
          <h3 class="text-sm font-bold text-primary uppercase tracking-widest mb-6 flex items-center gap-2">
            <span class="w-8 h-px bg-primary" /> {t('cv.education')}
          </h3>
          <div class="space-y-5">
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2">
              <div>
                <h4 class="font-bold text-near-black dark:text-text-light">Professioneel Diploma Software Engineering & Systeemontwikkeling</h4>
                <p class="text-sm text-cool-gray">Information Technology Institute (ITI) · Geaccrediteerd door MCIT Egypte</p>
              </div>
              <span class="text-xs font-mono text-cool-gray flex-shrink-0">2014 – 2015</span>
            </div>
            <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-2">
              <div>
                <h4 class="font-bold text-near-black dark:text-text-light">BSc. Handelswetenschappen <span class="text-cool-gray font-normal text-sm">(Cijfer: Goed)</span></h4>
                <p class="text-sm text-cool-gray">Universiteit van Mansoura · Egypte</p>
              </div>
              <span class="text-xs font-mono text-cool-gray flex-shrink-0">2008 – 2012</span>
            </div>
          </div>
        </div>

        <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
          <div>
            <h3 class="text-sm font-bold text-primary uppercase tracking-widest mb-4 flex items-center gap-2">
              <span class="w-8 h-px bg-primary" /> {t('cv.languages')}
            </h3>
            <div class="space-y-2">
              <div class="flex items-center justify-between text-sm">
                <span class="text-near-black dark:text-text-light font-medium">Engels</span>
                <span class="text-cool-gray">Uitstekend — Professioneel</span>
              </div>
              <div class="flex items-center justify-between text-sm">
                <span class="text-near-black dark:text-text-light font-medium">Nederlands</span>
                <span class="text-cool-gray">A2 — Lerende</span>
              </div>
            </div>
          </div>
          <div>
            <h3 class="text-sm font-bold text-primary uppercase tracking-widest mb-4 flex items-center gap-2">
              <span class="w-8 h-px bg-primary" /> {t('cv.certifications')}
            </h3>
            <div class="space-y-2">
              <div class="text-sm">
                <p class="text-near-black dark:text-text-light font-medium">Gecertificeerd Scrum Master (CSM)</p>
                <p class="text-cool-gray text-xs">Agile / Scrum methodologie</p>
              </div>
              <div class="text-sm">
                <p class="text-near-black dark:text-text-light font-medium">7× LinkedIn Vaardigheidstoets</p>
                <p class="text-cool-gray text-xs">C#, .NET, JS, jQuery, OOP, Git, Node.js</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
