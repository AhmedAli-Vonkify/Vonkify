---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactSection from '../components/ContactSection.astro';
import { SITE } from '../utils/constants';

const faqs = [
  {
    q: "What's your current availability?",
    a: "I'm available for freelance projects starting Q2 2026. I can take on full-time engagements, part-time (3-4 days/week), or project-based work.",
  },
  {
    q: "What's your hourly/daily rate?",
    a: "My rate depends on project scope, duration, and complexity. As a senior .NET & AI specialist, my rates are competitive with the Dutch market. Let's discuss — reach out and we'll find a structure that works.",
  },
  {
    q: "Do you work remotely?",
    a: "Yes, I'm fully set up for remote work. I'm also open to hybrid arrangements within the Netherlands (Rotterdam/Utrecht area primarily).",
  },
  {
    q: "What type of projects do you typically take on?",
    a: "Enterprise .NET/AI applications, API/middleware platforms, full-stack web apps (Angular + React + .NET), cloud architecture on Azure, and AI integration projects (RAG, LLMs, agents).",
  },
  {
    q: "Do you work alone or with a team?",
    a: "Both. I can work independently as a solo contractor or embed into your existing development team. I'm experienced at onboarding quickly into established codebases.",
  },
  {
    q: "What's your minimum project size?",
    a: "I prefer projects of at least 1 month duration to ensure quality delivery. For smaller tasks, I'm open to consulting engagements.",
  },
];
---

<BaseLayout
  title="Contact — Work with Ahmed Ali | Vonkify"
  description="Get in touch with Ahmed Ali — Senior .NET & AI Engineer available for freelance projects in the Netherlands. Fast response, professional service."
>
  <Header />

  <main class="pt-20">
    <!-- Page hero -->
    <section class="section-dark py-16 px-4 text-center">
      <div class="max-w-2xl mx-auto">
        <div class="inline-flex items-center gap-2 mb-5 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
          // Let's Connect
        </div>
        <h1 class="section-heading text-text-light mb-4">Get In Touch</h1>
        <p class="text-cool-gray text-lg">
          Have a project in mind? I'd love to hear about it. Send me a message and I'll get back to you within 24 hours.
        </p>
      </div>
    </section>

    <!-- Contact form section -->
    <ContactSection />

    <!-- FAQ -->
    <section class="section-light dark:section-dark py-20 px-4">
      <div class="max-w-3xl mx-auto">
        <div class="text-center mb-12 reveal">
          <h2 class="text-2xl font-bold text-near-black dark:text-text-light mb-3">Frequently Asked Questions</h2>
          <p class="text-cool-gray">Quick answers to common questions about working together.</p>
        </div>

        <div class="space-y-4">
          {
            faqs.map((faq, i) => (
              <details class="reveal group bg-white dark:bg-navy-light/40 border border-gray-100 dark:border-white/8 rounded-xl overflow-hidden hover:border-primary/25 transition-colors">
                <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none font-semibold text-near-black dark:text-text-light text-sm hover:text-primary transition-colors">
                  {faq.q}
                  <svg class="w-4 h-4 text-cool-gray flex-shrink-0 transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-6 pb-5 text-sm text-cool-gray leading-relaxed border-t border-gray-50 dark:border-white/5 pt-4">
                  {faq.a}
                </div>
              </details>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
