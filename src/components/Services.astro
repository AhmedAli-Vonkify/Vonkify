---
import { useTranslations, type Lang } from '../i18n';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
const prefix = lang === 'nl' ? '/nl' : '';

const services = [
  { icon: '🤖', titleKey: 'service.ai.title', descKey: 'service.ai.desc', tags: ['Azure OpenAI', 'RAG', 'LLMs', 'AI Agents'] },
  { icon: '⚙️', titleKey: 'service.backend.title', descKey: 'service.backend.desc', tags: ['.NET 8', 'CQRS', 'Microservices', 'DDD'] },
  { icon: '🖥️', titleKey: 'service.fullstack.title', descKey: 'service.fullstack.desc', tags: ['Angular', 'React', '.NET Core', 'SignalR'] },
  { icon: '☁️', titleKey: 'service.cloud.title', descKey: 'service.cloud.desc', tags: ['Azure', 'Terraform', 'Docker', 'Kubernetes'] },
  { icon: '🧪', titleKey: 'service.testing.title', descKey: 'service.testing.desc', tags: ['TDD', 'Jest', 'Cypress', 'SOLID'] },
  { icon: '👥', titleKey: 'service.leadership.title', descKey: 'service.leadership.desc', tags: ['Scrum', 'Architecture', 'Mentoring', 'Agile'] },
] as const;
---

<section id="services" class="section-light dark:section-dark py-24 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-16 reveal">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
        {t('services.chip')}
      </div>
      <h2 class="section-heading text-near-black dark:text-text-light mb-4">{t('services.heading')}</h2>
      <p class="text-cool-gray max-w-2xl mx-auto text-lg">{t('services.subheading')}</p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 stagger-children">
      {services.map((service) => (
        <div class="reveal group relative bg-white dark:bg-navy-light/50 border border-gray-100 dark:border-white/8 rounded-2xl p-7 hover:border-primary/30 hover:shadow-xl hover:shadow-primary/5 transition-all duration-300 hover:-translate-y-1">
          <div class="text-4xl mb-5">{service.icon}</div>
          <h3 class="text-lg font-bold text-near-black dark:text-text-light mb-3 group-hover:text-primary transition-colors">
            {t(service.titleKey)}
          </h3>
          <p class="text-sm text-cool-gray leading-relaxed mb-5">{t(service.descKey)}</p>
          <div class="flex flex-wrap gap-1.5">
            {service.tags.map((tag) => <span class="tech-badge text-xs">{tag}</span>)}
          </div>
          <div class="absolute bottom-0 left-0 right-0 h-0.5 bg-gradient-to-r from-primary to-accent rounded-b-2xl scale-x-0 group-hover:scale-x-100 transition-transform duration-300" />
        </div>
      ))}
    </div>

    <div class="text-center mt-14 reveal">
      <p class="text-cool-gray mb-5">{t('services.ctaSubtext')}</p>
      <a href={`${prefix}/contact`} class="btn-primary">
        {t('services.cta')}
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </div>
</section>
