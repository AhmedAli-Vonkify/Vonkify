---
import { TECH_CATEGORIES } from '../utils/constants';
import { useTranslations, type Lang } from '../i18n';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);

const categoryNameNl: Record<string, string> = {
  'Languages':      'Talen',
  'Backend':        'Backend',
  'Frontend':       'Frontend',
  'AI & ML':        'AI & ML',
  'Cloud & DevOps': 'Cloud & DevOps',
  'Databases':      'Databases',
  'Architecture':   'Architectuur',
  'Testing':        'Testen',
};

function catName(name: string) {
  return lang === 'nl' ? (categoryNameNl[name] ?? name) : name;
}
---

<section id="skills" class="section-light dark:section-dark py-24 px-4">
  <div class="max-w-7xl mx-auto">
    <div class="text-center mb-14 reveal">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
        {t('tech.chip')}
      </div>
      <h2 class="section-heading text-near-black dark:text-text-light mb-4">{t('tech.heading')}</h2>
      <p class="text-cool-gray max-w-2xl mx-auto">{t('tech.subheading')}</p>
    </div>

    <!-- LinkedIn assessment badges -->
    <div class="flex flex-wrap justify-center gap-2 mb-12 reveal">
      {['C#', '.NET', 'JavaScript', 'jQuery', 'OOP', 'Git', 'Node.js'].map((badge) => (
        <span
          class="inline-flex items-center gap-1.5 text-xs font-semibold px-3 py-1.5 rounded-full bg-[#0A66C2]/10 border border-[#0A66C2]/30 text-[#0A66C2] dark:text-blue-300 dark:border-blue-400/30 dark:bg-blue-400/8"
          title={t('tech.linkedin')}
        >
          <svg class="w-3 h-3" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
          </svg>
          ✓ {badge}
        </span>
      ))}
    </div>

    <!-- Categories grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-5">
      {TECH_CATEGORIES.map((cat) => (
        <div class="reveal bg-white dark:bg-navy-light/40 border border-gray-100 dark:border-white/8 rounded-xl p-5 hover:border-primary/25 transition-all duration-300">
          <div class="flex items-center gap-2 mb-4">
            <div class="w-1.5 h-5 bg-gradient-to-b from-primary to-accent rounded-full" />
            <h3 class="text-sm font-bold text-near-black dark:text-text-light uppercase tracking-wide">{catName(cat.name)}</h3>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {cat.items.map((item) => (
              <span class={`text-xs px-2.5 py-1 rounded-full border font-medium transition-colors ${
                cat.assessments.includes(item)
                  ? 'border-primary/40 text-primary bg-primary/8'
                  : 'border-gray-200 dark:border-white/10 text-cool-gray bg-gray-50 dark:bg-white/3 hover:border-primary/30 hover:text-primary'
              }`}>
                {item}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
