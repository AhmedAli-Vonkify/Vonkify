---
import { getCollection } from 'astro:content';
import ProjectCard from './ProjectCard.astro';

const allProjects = await getCollection('projects');
const featured = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => (a.data.featuredOrder ?? 99) - (b.data.featuredOrder ?? 99))
  .slice(0, 4);
---

<section id="projects" class="section-dark py-24 px-4">
  <div class="max-w-7xl mx-auto">
    <!-- Heading -->
    <div class="flex flex-col sm:flex-row sm:items-end justify-between gap-6 mb-14">
      <div class="reveal">
        <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
          // Featured Work
        </div>
        <h2 class="section-heading text-text-light">Selected Projects</h2>
        <p class="text-cool-gray mt-3 max-w-xl">
          A selection of my most impactful work — from AI-powered platforms to enterprise infrastructure.
        </p>
      </div>
      <a href="/projects" class="btn-outline self-start sm:self-auto flex-shrink-0 reveal">
        View All Projects
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>

    <!-- Projects grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 stagger-children">
      {
        featured.map((project) => (
          <div class="reveal">
            <ProjectCard
              slug={project.id}
              title={project.data.title}
              company={project.data.company}
              period={project.data.period}
              summary={project.data.summary}
              tech={project.data.tech}
              category={project.data.category}
              featured={project.data.featured}
            />
          </div>
        ))
      }
    </div>
  </div>
</section>
