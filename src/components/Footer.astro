---
import { SITE } from '../utils/constants';
import { useTranslations, type Lang } from '../i18n';

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
const prefix = lang === 'nl' ? '/nl' : '';
const year = new Date().getFullYear();

const navLinks = [
  { href: `${prefix}/#services`, label: t('nav.services') },
  { href: `${prefix}/projects`, label: t('nav.projects') },
  { href: `${prefix}/about`, label: t('nav.about') },
  { href: `${prefix}/cv`, label: t('nav.cv') },
  { href: `${prefix}/contact`, label: t('nav.contact') },
];
---

<footer class="section-dark border-t border-white/8">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">
      <!-- Brand -->
      <div>
        <a href={lang === 'nl' ? '/nl/' : '/'} class="flex items-center gap-2.5 mb-4 group w-fit">
          <div class="w-8 h-8 rounded-md flex items-center justify-center bg-primary/10 border border-primary/30">
            <svg viewBox="0 0 32 32" fill="none" class="w-6 h-6">
              <path d="M20 3L7 17.5H15.5L13 29L27 13H18L20 3Z" fill="#FF6B00" stroke="#FFB800" stroke-width="0.5" stroke-linejoin="round" />
            </svg>
          </div>
          <span class="font-brand font-semibold text-lg text-text-light">vonkify</span>
        </a>
        <p class="text-sm text-cool-gray leading-relaxed max-w-xs">{t('footer.tagline')}</p>
        <div class="flex items-center gap-2 mt-4 text-xs font-semibold text-success">
          <span class="w-1.5 h-1.5 bg-success rounded-full animate-pulse" />
          {t('footer.available')}
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="text-sm font-semibold text-text-light mb-4 uppercase tracking-wider">{t('footer.nav')}</h3>
        <ul class="space-y-2.5">
          {navLinks.map((link) => (
            <li><a href={link.href} class="text-sm text-cool-gray hover:text-primary transition-colors">{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold text-text-light mb-4 uppercase tracking-wider">{t('footer.contact')}</h3>
        <ul class="space-y-3">
          <li>
            <a href={`mailto:${SITE.email}`} class="flex items-center gap-2.5 text-sm text-cool-gray hover:text-primary transition-colors group">
              <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
              </svg>
              {SITE.email}
            </a>
          </li>
          <li>
            <a href={SITE.linkedin} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-sm text-cool-gray hover:text-primary transition-colors">
              <svg class="w-4 h-4 text-primary flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
              </svg>
              LinkedIn
            </a>
          </li>
          <li>
            <a href={SITE.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2.5 text-sm text-cool-gray hover:text-primary transition-colors">
              <svg class="w-4 h-4 text-primary flex-shrink-0" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.374 0 0 5.373 0 12c0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23A11.509 11.509 0 0112 5.803c1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576C20.566 21.797 24 17.3 24 12c0-6.627-5.373-12-12-12z" />
              </svg>
              GitHub
            </a>
          </li>
          <li class="flex items-center gap-2.5 text-sm text-cool-gray">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
              <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
            </svg>
            {lang === 'nl' ? 'Rotterdam, Nederland' : 'Rotterdam, Netherlands'}
          </li>
        </ul>
      </div>
    </div>

    <div class="border-t border-white/8 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-cool-gray">
        © {year} <span class="text-primary font-medium">Vonkify</span> · Ahmed Ali · {t('footer.copyright')}
      </p>
      <p class="text-xs text-cool-gray">
        {t('footer.built')} <span class="text-primary">Astro</span> & <span class="text-primary">Tailwind CSS</span> · Vercel
      </p>
    </div>
  </div>
</footer>
