---
const clients = [
  { name: 'iO Digital', logo: '🔷', url: 'https://www.iodigital.com' },
  { name: 'Eneco', logo: '⚡', url: 'https://www.eneco.nl' },
  { name: 'Heijmans', logo: '🏗️', url: 'https://www.heijmans.nl' },
  { name: 'Omniplan', logo: '📊', url: 'https://omniplan.nl' },
  { name: 'ICT Group', logo: '💻', url: 'https://www.ictgroup.eu' },
  { name: 'Stedin', logo: '🔌', url: 'https://www.stedin.net' },
];

const trustStats = [
  { value: '10+', label: 'Years Experience' },
  { value: '5+', label: 'Major Companies' },
  { value: '7', label: 'LinkedIn Skill Badges' },
  { value: '€95+', label: 'Senior Rate/Hour' },
];
---

<section id="clients" class="section-dark py-24 px-4">
  <div class="max-w-7xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-14 reveal">
      <div class="inline-flex items-center gap-2 mb-4 px-3 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono">
        // Social Proof
      </div>
      <h2 class="section-heading text-text-light mb-4">Companies I've Worked With</h2>
      <p class="text-cool-gray max-w-xl mx-auto">
        Enterprise experience across energy, construction, finance, healthcare, and digital sectors in the Netherlands.
      </p>
    </div>

    <!-- Client logos -->
    <div class="flex flex-wrap justify-center gap-4 mb-16 reveal">
      {
        clients.map((client) => (
          <a
            href={client.url}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2.5 px-5 py-3 bg-white/4 border border-white/8 rounded-xl hover:border-primary/30 hover:bg-white/8 transition-all duration-300 group"
          >
            <span class="text-2xl">{client.logo}</span>
            <span class="text-sm font-semibold text-cool-gray group-hover:text-text-light transition-colors">
              {client.name}
            </span>
          </a>
        ))
      }
    </div>

    <!-- Trust stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-16 reveal">
      {
        trustStats.map((stat) => (
          <div class="text-center p-5 bg-white/3 border border-white/8 rounded-xl">
            <div class="text-3xl font-bold gradient-text mb-1">{stat.value}</div>
            <div class="text-xs text-cool-gray font-medium">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <!-- LinkedIn recommendation CTA -->
    <div class="reveal text-center">
      <div class="inline-block max-w-xl bg-white/4 border border-white/10 rounded-2xl px-8 py-7">
        <div class="flex items-center justify-center gap-2 mb-3">
          <svg class="w-5 h-5 text-[#0A66C2]" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
            />
          </svg>
          <span class="text-sm font-semibold text-text-light">Recommendations on LinkedIn</span>
        </div>
        <p class="text-sm text-cool-gray mb-4">
          Colleagues and clients have endorsed my work with 7 LinkedIn skill assessments passed and professional recommendations.
        </p>
        <a
          href="https://www.linkedin.com/in/ahmed-ali-vonkify"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 text-sm font-semibold text-[#0A66C2] hover:text-blue-300 transition-colors"
        >
          View My LinkedIn Profile
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>
