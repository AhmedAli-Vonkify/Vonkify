---
import SparkParticles from './SparkParticles.tsx';
import { STATS, AVAILABILITY } from '../utils/constants';

const techPills = ['C#', '.NET 8', 'Azure OpenAI', 'React', 'Angular', 'Docker', 'Terraform'];
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-navy" aria-label="Hero">
  <!-- Particle layer -->
  <SparkParticles client:only="react" />

  <!-- Dot grid background -->
  <div
    class="absolute inset-0 opacity-10"
    style="background-image: radial-gradient(rgba(255,107,0,0.6) 1px, transparent 1px); background-size: 32px 32px;"
  >
  </div>

  <!-- Gradient overlays -->
  <div class="absolute inset-0 bg-gradient-to-b from-navy/20 via-transparent to-navy/80 pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-navy to-transparent pointer-events-none"></div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-32 text-center">
    <!-- Pre-heading chip -->
    <div
      class="inline-flex items-center gap-2 mb-8 px-4 py-2 rounded-full bg-white/5 border border-primary/25 text-primary text-sm font-mono animate-fade-in"
    >
      <span class="w-1.5 h-1.5 bg-primary rounded-full animate-pulse"></span>
      // Senior Software Engineer & AI Integration Specialist
    </div>

    <!-- Main heading -->
    <h1 class="section-heading text-text-light mb-6 max-w-4xl mx-auto animate-fade-in-up">
      I build intelligent software that
      <span class="gradient-text block sm:inline"> sparks innovation</span>
    </h1>

    <!-- Subheading -->
    <p
      class="text-lg sm:text-xl text-cool-gray max-w-3xl mx-auto mb-10 leading-relaxed animate-fade-in-up"
      style="animation-delay: 150ms;"
    >
      Senior .NET & AI Engineer with <strong class="text-text-light font-semibold">10+ years</strong> of experience crafting
      robust enterprise solutions. Specializing in AI Integration, Cloud Architecture, and Full-Stack Development.
    </p>

    <!-- CTA Buttons -->
    <div
      class="flex flex-col sm:flex-row gap-4 justify-center mb-16 animate-fade-in-up"
      style="animation-delay: 250ms;"
    >
      <a href="/contact" class="btn-primary text-base">
        Let's Talk
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
      <a href="#projects" class="btn-secondary text-base">
        View My Work
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>

    <!-- Stats -->
    <div
      class="grid grid-cols-2 sm:grid-cols-4 gap-6 mb-12 max-w-2xl mx-auto animate-fade-in-up"
      style="animation-delay: 350ms;"
    >
      {
        STATS.map((stat) => (
          <div class="text-center">
            <div class="text-3xl sm:text-4xl font-bold gradient-text mb-1">{stat.value}</div>
            <div class="text-xs text-cool-gray font-medium">{stat.label}</div>
          </div>
        ))
      }
    </div>

    <!-- Availability badge -->
    {
      AVAILABILITY.isAvailable && (
        <div
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full bg-success/8 border border-success/25 text-success text-sm font-semibold mb-12 animate-fade-in-up"
          style="animation-delay: 450ms;"
        >
          <span class="w-2 h-2 bg-success rounded-full animate-pulse" />
          {AVAILABILITY.label} — {AVAILABILITY.period}
        </div>
      )
    }

    <!-- Tech pills -->
    <div class="flex flex-wrap justify-center gap-2.5 opacity-50 animate-fade-in" style="animation-delay: 550ms;">
      {techPills.map((tech) => (
        <span class="text-xs font-mono text-cool-gray border border-white/10 px-3 py-1.5 rounded-full bg-white/3">
          {tech}
        </span>
      ))}
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce-y">
    <a href="#services" aria-label="Scroll to services">
      <svg class="w-6 h-6 text-cool-gray/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
      </svg>
    </a>
  </div>
</section>
