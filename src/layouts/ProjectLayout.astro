---
import BaseLayout from './BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE } from '../utils/constants';
import { useTranslations, type Lang } from '../i18n';

export interface Props {
  title: string;
  company: string;
  period: string;
  role: string;
  roleNl?: string;
  summary: string;
  summaryNl?: string;
  tech: string[];
  category: string;
}

const lang = (Astro.currentLocale ?? 'en') as Lang;
const t = useTranslations(lang);
const prefix = lang === 'nl' ? '/nl' : '';

const { title, company, period, role, roleNl, summary, summaryNl, tech, category } = Astro.props;
const pageTitle = `${title} — ${company} | ${SITE.name}`;
const displayRole = lang === 'nl' && roleNl ? roleNl : role;
const displaySummary = lang === 'nl' && summaryNl ? summaryNl : summary;
const displayPeriod = lang === 'nl' ? period.replace('Present', 'Heden') : period;

const categoryColors: Record<string, string> = {
  'AI & ML': 'from-violet-500/20 to-primary/20 border-violet-400/30 text-violet-300',
  'Backend': 'from-primary/20 to-accent/20 border-primary/30 text-primary',
  'Full-Stack': 'from-blue-500/20 to-primary/20 border-blue-400/30 text-blue-300',
  'Cloud': 'from-sky-500/20 to-primary/20 border-sky-400/30 text-sky-300',
  'Blockchain': 'from-emerald-500/20 to-primary/20 border-emerald-400/30 text-emerald-300',
  'Healthcare': 'from-rose-500/20 to-primary/20 border-rose-400/30 text-rose-300',
};
const catColor = categoryColors[category] ?? 'from-primary/20 to-accent/20 border-primary/30 text-primary';
---

<BaseLayout title={pageTitle} description={summary}>
  <Header />

  <main class="pt-20">

    <!-- Hero -->
    <section class="section-dark relative overflow-hidden py-20 px-4">
      <!-- Background grid -->
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#FF6B00 1px, transparent 1px), linear-gradient(90deg, #FF6B00 1px, transparent 1px); background-size: 60px 60px;"></div>
      <!-- Gradient orb -->
      <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-5" style="background: radial-gradient(circle, #FF6B00, transparent 70%);"></div>

      <div class="relative max-w-4xl mx-auto">
        <!-- Back link -->
        <div class="mb-8">
          <a
            href={`${prefix}/projects`}
            class="inline-flex items-center gap-2 text-sm text-cool-gray hover:text-primary transition-colors group"
          >
            <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            {t('projects.back')}
          </a>
        </div>

        <!-- Category badge -->
        <div class={`inline-flex items-center gap-2 mb-5 px-3 py-1.5 rounded-full bg-gradient-to-r ${catColor} border text-xs font-mono font-medium`}>
          {category}
        </div>

        <!-- Title -->
        <h1 class="text-4xl md:text-5xl font-bold text-text-light mb-4 leading-tight">{title}</h1>

        <!-- Meta row -->
        <div class="flex flex-wrap gap-5 mb-6 text-sm text-cool-gray">
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
            </svg>
            <span class="hover:text-text-light transition-colors">{company}</span>
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
            {displayPeriod}
          </span>
          <span class="flex items-center gap-1.5">
            <svg class="w-4 h-4 text-primary flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            {displayRole}
          </span>
        </div>

        <!-- Summary -->
        <p class="text-lg text-cool-gray leading-relaxed mb-8 max-w-3xl">{displaySummary}</p>

        <!-- Tech stack -->
        <div class="flex flex-wrap gap-2">
          {tech.map((t) => <span class="tech-badge">{t}</span>)}
        </div>
      </div>
    </section>

    <!-- Divider gradient -->
    <div class="h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

    <!-- Content -->
    <section class="section-dark py-16 px-4">
      <div class="max-w-4xl mx-auto">

        <!-- Slot content (achievements + body) -->
        <div class="project-prose">
          <slot />
        </div>

      </div>
    </section>

    <!-- Divider gradient -->
    <div class="h-px bg-gradient-to-r from-transparent via-primary/30 to-transparent"></div>

    <!-- CTA -->
    <section class="section-dark py-16 px-4 text-center relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(#FF6B00 1px, transparent 1px); background-size: 32px 32px;"></div>
      <div class="relative max-w-xl mx-auto">
        <div class="w-12 h-px bg-gradient-to-r from-transparent via-primary to-transparent mx-auto mb-6"></div>
        <p class="text-cool-gray mb-8 text-lg">{t('projects.interested')}</p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href={`${prefix}/contact`} class="btn-primary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
            </svg>
            {t('hero.ctaPrimary')}
          </a>
          <a href={`${prefix}/projects`} class="btn-secondary">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7" />
            </svg>
            {t('projects.viewAll')}
          </a>
        </div>
      </div>
    </section>

  </main>

  <Footer />
</BaseLayout>
